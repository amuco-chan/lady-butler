# Private key shared by the Lady Butler app and the Custom GPT Action.
SYNC_ACCESS_TOKEN=replace-with-a-long-random-value

# Added automatically when an Upstash Redis integration is linked in Vercel.
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-standard-token
